{
  "trigger": {
    "app": "Facebook Lead Ads",
    "event": "New Lead",
    "lead_details": {
      "id": "lead_1234567890",
      "created_time": "2026-07-17T15:35:47+04:00",
      "ad_id": "ad_0987654321",
      "ad_name": "Q3 B2B Marketing Campaign",
      "adset_id": "adset_11223344",
      "adset_name": "Tech Executives US",
      "campaign_id": "camp_55667788",
      "campaign_name": "Alba AI Q3 Launch",
      "form_id": "form_99887766",
      "form_name": "Alba AI Early Access Sign Up"
    },
    "field_data": {
      "full_name": "Jane Doe",
      "email": "jane.doe@example.com",
      "phone_number": "+1-555-012-3456",
      "company_name": "Acme Innovations Ltd",
      "job_title": "Chief Technology Officer",
      "industry": "Artificial Intelligence"
    }
  },
  "action": {
    "app": "Webhooks by Zapier",
    "event": "Custom Request (POST)",
    "configuration": {
      "url": "https://n8n.alba-ai.com/webhook/catch-fb-lead",
      "payload_type": "json",
      "headers": {
        "Authorization": "Bearer YOUR_N8N_API_TOKEN_HERE",
        "Content-Type": "application/json",
        "X-Source": "Zapier-Facebook-Lead-Ads"
      },
      "data": {
        "source": "facebook_lead_ads",
        "timestamp": "{{trigger.lead_details.created_time}}",
        "lead_id": "{{trigger.lead_details.id}}",
        "contact_info": {
          "name": "{{trigger.field_data.full_name}}",
          "email": "{{trigger.field_data.email}}",
          "phone": "{{trigger.field_data.phone_number}}"
        },
        "business_info": {
          "company": "{{trigger.field_data.company_name}}",
          "title": "{{trigger.field_data.job_title}}",
          "industry": "{{trigger.field_data.industry}}"
        },
        "attribution": {
          "campaign_name": "{{trigger.lead_details.campaign_name}}",
          "adset_name": "{{trigger.lead_details.adset_name}}",
          "ad_name": "{{trigger.lead_details.ad_name}}"
        }
      }
    }
  },
  "metadata": {
    "workflow_name": "FB Lead Catch & Throw to n8n",
    "version": "1.0",
    "author": "Zapier Integration Architect",
    "last_updated": "2026-07-17T15:35:47+04:00"
  }
}
