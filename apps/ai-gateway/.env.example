# AutoDealer AI Gateway — Environment Variables
# Copy this file to .env and fill in your values

# ─── OpenRouter (LLM API) ──────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Supabase (Database) ───────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ─── Internal Service URLs ─────────────────────────────
CRM_API_URL=https://autodealer-crm-api.onrender.com
MARKETING_API_URL=https://autodealer-marketing.onrender.com
DASHBOARD_URL=https://autodealer-dashboard.onrender.com

# ─── Security ──────────────────────────────────────────
API_SECRET_KEY=generate_a_random_secret_here
N8N_SYSTEM_TOKEN=generate_another_random_token_here
ZAPIER_SECRET=generate_a_zapier_webhook_secret

# ─── App Config ────────────────────────────────────────
ENVIRONMENT=production
PORT=8000
