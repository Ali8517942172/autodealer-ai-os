    "Is HOT Lead?": {
      "main": [
        [{ "node": "Respond: Success", "type": "main", "index": 0 }],
        [{ "node": "Respond: Queued", "type": "main", "index": 0 }]
      ]
    }
  },
  "pinData": {},
